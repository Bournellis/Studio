# DraxosMobile - Internal Alpha v0 remote example
#
# Copy these values to a local-only env file or set them in the terminal.
# Do not commit real .env files.

DRAXOS_MOBILE_BACKEND_ENV=internal_alpha_v0
DRAXOS_MOBILE_SUPABASE_URL=https://<project-ref>.supabase.co
DRAXOS_MOBILE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<public-key>

# Server deploy, seeders and remote smokes only.
# Never expose the service role key to Godot exports, web builds, APKs or docs.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
