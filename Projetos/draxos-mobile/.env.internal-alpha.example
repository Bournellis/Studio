# DraxosMobile - Internal Alpha v0 remote example
#
# Copy these values to a local-only env file or set them in the terminal.
# Do not commit real .env files.

DRAXOS_MOBILE_BACKEND_ENV=internal_alpha_v0
SUPABASE_PROJECT_REF=<project-ref>
DRAXOS_MOBILE_SUPABASE_URL=https://<project-ref>.supabase.co
DRAXOS_MOBILE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<public-key>
DRAXOS_MOBILE_RELEASE_CHANNEL=internal_alpha
DRAXOS_MOBILE_RELEASE_VERSION=0.0.1-alpha.0
DRAXOS_MOBILE_UPDATE_MANIFEST_URL=https://<project-ref>.supabase.co/functions/v1/release/manifest
DRAXOS_MOBILE_PORTAL_URL=https://<host>/draxos-mobile/internal-alpha/

# Optional Android release signing for wider internal distribution.
# If these are absent, tools/export_internal_alpha.ps1 can use debug fallback
# only when explicitly called with -AllowAndroidDebugFallback.
DRAXOS_MOBILE_ANDROID_KEYSTORE_RELEASE_PATH=D:\secrets\draxos-mobile-alpha.keystore
DRAXOS_MOBILE_ANDROID_KEYSTORE_RELEASE_USER=draxos_mobile_alpha
DRAXOS_MOBILE_ANDROID_KEYSTORE_RELEASE_PASSWORD=<keystore-password>

# Server deploy, seeders and remote smokes only.
# Never expose the service role key to Godot exports, web builds, APKs or docs.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
