"boss_part_slots": [0.0, 2.0, 5.0],
"display_name": "Nucleo Fragmentado",
"id": "colosso_fragmentado",
"mode": "chefe_multiparte",
"notes": "Primeiro encontro do modo chefe_multiparte. O objetivo e destruir as partes marcadas do chefe: E1, E3 e ET. Suportes inimigos podem permanecer vivos; a vitoria nao exige limpar toda a mesa.",
"reward_cards": ["campeao_guilda"],
"starting_enemy_slots": [{
