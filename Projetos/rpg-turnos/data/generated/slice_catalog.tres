"slot": 2.0
}],
"wave_number": 2.0
}]
}, {
"board_id": "muralha_desfiladeiro",
"defense_turn_limit": 2.0,
"display_name": "Defesa da Base de Ether",
"id": "defesa_do_portao",
"mode": "defesa",
"notes": "Primeiro encontro do modo defesa. O objetivo e sobreviver a dois turnos inimigos completos, sem heroi inimigo e sem vitoria automatica por limpar a mesa. O jogador conserva o fluxo normal de mao, deck e energia enquanto segura a pressao inicial.",
"reward_cards": ["guardiao_portal"],
"starting_enemy_slots": [{
