encounters = Array[Dictionary]([{
"board_id": "ponte_estavel",
"display_name": "Operacao de Pouso",
"id": "emboscada_na_ponte",
"mode": "limpar_mesa",
"reward_cards": ["lobo_alfa"],
"starting_enemy_slots": [{
