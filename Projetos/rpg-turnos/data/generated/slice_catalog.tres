"id": "enigma_da_ponte",
"mode": "quebra_cabeca",
"notes": "Primeiro encontro do modo quebra_cabeca. O objetivo e limpar os alvos E1 e E3 em ate dois turnos do jogador. O suporte em E2 pode permanecer vivo; a vitoria nao exige limpar toda a mesa.",
"puzzle_target_slots": [0.0, 2.0],
