track_contract = {
"board_effect_definitions": [{
"display_name": "Terreno Rochoso",
"id": "terreno_rochoso",
"tooltip": "Criaturas aliadas pequenas invocadas nas bordas perdem 1 ATK."
}, {
"display_name": "Chao Vivo",
"id": "chao_vivo",
"tooltip": "No inicio da preparacao inimiga, uma criatura inimiga ganha +0/+1."
}, {
"display_name": "Geada",
"id": "geada",
"tooltip": "No inicio do turno do jogador, uma criatura aliada aleatoria fica Congelada."
}, {
"display_name": "Corrente Submersa",
"id": "corrente_submersa",
"tooltip": "Movimento e troca de slots aliados ficam bloqueados."
}, {
"display_name": "Tabuleiro Instavel",
"id": "tabuleiro_instavel",
"tooltip": "A cada dois turnos, uma criatura aleatoria fica Congelada por um ataque."
}, {
"display_name": "Frio Intenso",
"id": "frio_intenso",
"tooltip": "Efeitos de morte e ressurgimento sao anulados enquanto ativo."
}, {
"display_name": "Nevasca",
"id": "nevasca",
"tooltip": "O limite de mao do jogador e reduzido em 1 durante o encontro."
}, {
"display_name": "Ventania",
"id": "ventania",
"tooltip": "No inicio da preparacao inimiga, duas lanes inimigas adjacentes podem trocar."
}, {
"display_name": "Slot Central Amplificado",
"id": "slot_central_amplificado",
"tooltip": "Criaturas no slot central recebem +1 ATK; inimigo no centro causa pressao direta."
}, {
"display_name": "Relampago",
"id": "relampago",
"tooltip": "No inicio do turno do jogador, uma criatura aleatoria recebe 2 de dano."
}, {
"display_name": "Turbulencia",
"id": "turbulencia",
"tooltip": "Criaturas invocadas entram com -1 HP, minimo 1."
}, {
"display_name": "Olho da Tempestade",
"id": "olho_tempestade",
"tooltip": "A partir do turno 4, combina Ventania e Relampago."
}, {
"display_name": "Brasa Viva",
"id": "brasa_viva",
"tooltip": "Ao fim do combate, criaturas com 1 HP sofrem 1 dano."
}, {
"display_name": "Inferno",
"id": "inferno",
"tooltip": "No inicio da preparacao inimiga, uma criatura aliada recebe Veneno 1."
}, {
"display_name": "Piso de Lava",
"id": "piso_lava",
"tooltip": "A retaguarda aliada sofre 1 dano por turno."
}, {
"display_name": "Furia do Abismo",
"id": "furia_abismo",
"tooltip": "Mortes inimigas chamam fragmentos enfurecidos quando ha espaco."
}, {
"display_name": "Cinzas Vivas",
"id": "cinzas_vivas",
"tooltip": "Criaturas com base HP 3+ deixam uma Brasa 1/1 ao morrer."
}, {
"display_name": "Portal Aberto",
"id": "portal_aberto",
"tooltip": "Nos turnos 3 e 5, o portal invoca reforcos no grupo menor."
}, {
"display_name": "Inferno Total",
"id": "inferno_total",
"tooltip": "Combina Brasa Viva reforcada, Veneno aleatorio e Brasas de criaturas grandes."
}],
"enemy_card_galleries": {
"ar": ["enemy_ar_elemental_de_vento", "enemy_ar_silfo", "enemy_ar_brisa_mortal", "enemy_ar_tempestade_vivente", "enemy_ar_corvo_da_tormenta", "enemy_ar_elemental_do_raio", "enemy_ar_rajada"],
"fogo": ["enemy_fogo_elemental_de_chama", "enemy_fogo_salamandra", "enemy_fogo_golem_de_lava", "enemy_fogo_demonio_de_chama", "enemy_fogo_fragmento_de_chama", "enemy_fogo_fenix"],
"gelo": ["enemy_gelo_cristal_de_gelo", "enemy_gelo_elemental_de_gelo", "enemy_gelo_golem_de_gelo", "enemy_gelo_djinn_do_frio", "enemy_gelo_espirito_da_geada", "enemy_gelo_fenix_de_gelo", "enemy_gelo_coluna_de_gelo"],
"terra": ["enemy_terra_elemental_areia", "enemy_terra_elemental_pedra", "enemy_terra_elemental_agil", "enemy_terra_elemental_bruto", "enemy_terra_golem_terra", "enemy_terra_guerreiro_terra", "enemy_terra_verme_terra", "enemy_terra_elemental_tita", "enemy_terra_rocha_viva", "enemy_terra_elemental_granito"]
},
"enemy_intent_definitions": [{
"display_name": "Pressao de Lane",
"id": "lane_pressure",
"tooltip": "Intent: o inimigo tende a ocupar ou atacar lanes com melhor dano imediato."
}, {
"display_name": "Quebrar Defensor",
"id": "defender_break",
"tooltip": "Intent: o inimigo prioriza remover ou contornar criaturas com Defensor."
}, {
"display_name": "Controle",
"id": "control_target",
"tooltip": "Intent: o inimigo tende a aplicar controle no alvo de maior impacto."
}, {
"display_name": "Fase de Chefe",
"id": "boss_phase",
"tooltip": "Intent: mostra fase atual, gatilho e proxima acao especial prevista."
}, {
"display_name": "Dano Previsto",
"id": "incoming_pressure",
"tooltip": "Intent: resume a pressao ou dano provavel do proximo ciclo."
}],
"id": "track_02_complete_run_evolution",
"keyword_definitions": [{
"display_name": "Iniciativa",
"id": "iniciativa",
"status": "implemented",
"summary": "Ataca antes do alvo frontal na lane.",
"timing": "combate",
"tooltip": "Causa dano primeiro na lane. Se destruir o alvo, nao recebe dano de retorno."
}, {
"display_name": "Defensor",
"id": "defensor",
"status": "implemented",
"summary": "Protege lanes vazias.",
"timing": "combate",
"tooltip": "Atrai ataques de criaturas inimigas que nao tem alvo frontal, protegendo o Comandante."
}, {
"display_name": "Reviver",
"id": "reviver",
"status": "implemented",
"summary": "Retorna uma vez com stats originais.",
"timing": "morte",
"tooltip": "Quando morre, volta uma vez no mesmo slot com ATK/HP originais e recebe um marcador de revive usado."
}, {
"display_name": "Regeneracao X",
"id": "regeneracao",
"status": "implemented",
"summary": "Recupera HP apos o combate.",
"timing": "manutencao",
"tooltip": "No fim de cada Resolver Combate, recupera X HP enquanto estiver viva."
}, {
"display_name": "Carnica X",
"id": "carnica",
"status": "implemented",
"summary": "Cresce quando outra criatura morre.",
"timing": "morte",
"tooltip": "Sempre que outra criatura morre em campo, ganha +X/+X permanente durante a batalha."
}, {
"display_name": "Suicida X",
"id": "suicida",
"status": "implemented",
"summary": "Morre causando dano.",
"timing": "combate",
"tooltip": "Ao agir ou morrer pelo proprio efeito, causa X de dano conforme definido pela carta."
}, {
"display_name": "Enfraquecer X",
"id": "enfraquecer",
"status": "implemented",
"summary": "Reduz ATK e HP.",
"timing": "efeito",
"tooltip": "Reduz ATK e HP maximo do alvo em X. Se o HP chegar a 0, o alvo morre."
}, {
"display_name": "Prender",
"id": "prender",
"status": "implemented",
"summary": "Impede o proximo ataque.",
"timing": "proximo_combate",
"tooltip": "O alvo nao ataca no proximo Resolver Combate."
}, {
"display_name": "Remover Keywords",
"id": "remover_keywords",
"status": "implemented",
"summary": "Apaga keywords do alvo.",
"timing": "efeito",
"tooltip": "Remove as keywords da criatura alvo e desliga seus marcadores derivados quando aplicavel."
}, {
"display_name": "Poder de Habilidade",
"id": "poder_de_habilidade",
"status": "implemented",
"summary": "Aumenta dano de spells e poderes.",
"timing": "enquanto_ativo",
"tooltip": "Bonus temporario ou de aura usado por cartas e classe Arcano para aumentar dano de efeitos diretos."
}, {
"display_name": "Atropelar",
"id": "atropelar",
"status": "implemented",
"summary": "Excesso de dano continua na lane.",
"timing": "combate",
"tooltip": "Quando causa mais dano que o HP do alvo frontal, o excesso segue para o proximo alvo valido na lane."
}, {
"display_name": "Brutal",
"id": "brutal",
"status": "implemented",
"summary": "Dano lateral em lanes adjacentes.",
"timing": "combate",
"tooltip": "Ao atacar e causar dano ao alvo frontal, tambem causa 1 de dano a criaturas inimigas nas lanes adjacentes."
}, {
"display_name": "Drenar X",
"id": "drenar",
"status": "implemented",
"summary": "Dano de combate cura o Comandante.",
"timing": "dano_de_combate",
"tooltip": "Quando esta criatura causa dano em combate, o Comandante aliado recupera X HP."
}, {
"display_name": "Espinhos X",
"id": "espinhos",
"status": "implemented",
"summary": "Devolve dano ao atacante.",
"timing": "ao_sofrer_dano",
"tooltip": "Quando sofre dano de um ataque, causa X de dano de volta imediatamente a criatura atacante."
}, {
"display_name": "Escudo",
"id": "escudo",
"status": "implemented",
"summary": "Ignora a primeira instancia de dano.",
"timing": "ao_sofrer_dano",
"tooltip": "A primeira instancia de dano recebida e ignorada; depois o Escudo e consumido."
}, {
"display_name": "Resistencia X",
"id": "resistencia",
"status": "implemented",
"summary": "Reduz dano por ciclo.",
"timing": "por_ciclo",
"tooltip": "Ignora os primeiros X pontos de dano recebidos a cada ciclo de combate."
}, {
"display_name": "Imune",
"id": "imune",
"scope": "elite_or_boss_recommended",
"status": "implemented",
"summary": "Nao recebe efeitos negativos.",
"timing": "continuo",
"tooltip": "Nao pode ser alvo de spells, habilidades ativas ou efeitos negativos. Ainda pode ser atacada em combate de lane."
}, {
"display_name": "Crescer X",
"id": "crescer",
"status": "implemented",
"summary": "Ganha ATK no inicio do turno.",
"timing": "inicio_turno",
"tooltip": "No inicio de cada turno do jogador, ganha +X ATK permanente enquanto estiver em campo."
}, {
"display_name": "Furia",
"id": "furia",
"status": "implemented",
"summary": "Ganha ATK ao sobreviver dano.",
"timing": "fim_combate",
"tooltip": "Quando sofre dano e sobrevive ao ciclo de combate, ganha +1 ATK permanente."
}, {
"display_name": "Ecoar",
"id": "ecoar",
"status": "implemented",
"summary": "Repete o primeiro dano uma vez.",
"timing": "dano_de_combate",
"tooltip": "Uma vez por batalha, quando causa dano, repete o mesmo dano no mesmo alvo imediatamente."
}, {
"display_name": "Veneno X",
"id": "veneno",
"status": "implemented",
"summary": "Dano periodico acumulavel.",
"timing": "fim_turno",
"tooltip": "Ao causar dano, aplica Veneno X. No fim do turno do jogador, o alvo perde HP igual ao valor acumulado."
}, {
"display_name": "Congelar",
"id": "congelar",
"status": "implemented",
"summary": "Faz o alvo pular o proximo ataque.",
"timing": "proximo_combate",
"tooltip": "Quando aplicado, a criatura atingida nao ataca no proximo ciclo de combate."
}, {
"display_name": "Profanar",
"id": "profanar",
"scope": "enemy_or_boss_recommended",
"status": "implemented",
"summary": "Remove keywords ao morrer.",
"timing": "morte",
"tooltip": "Quando esta criatura morre, remove todas as keywords de uma criatura inimiga aleatoria em campo."
}, {
"display_name": "Entrar",
"id": "entrar",
"status": "implemented",
"summary": "Dispara efeito ao ser invocada.",
"timing": "invocacao",
"tooltip": "Ao ser invocada, dispara o efeito escrito na carta antes do proximo combate."
}, {
"display_name": "Proliferar",
"id": "proliferar",
"status": "implemented",
"summary": "Cria token se sobreviver.",
"timing": "fim_combate",
"tooltip": "Se sobreviver ate o fim do ciclo de combate, cria um token 1/1 sem keywords em slot aliado vazio."
}, {
"display_name": "Sacrificio X",
"id": "sacrificio",
"status": "implemented",
"summary": "Reduz custo sacrificando aliada.",
"timing": "jogar_carta",
"tooltip": "Ao jogar esta carta, voce pode sacrificar uma criatura aliada para reduzir o custo de mana em X."
}, {
"display_name": "Inspirar X",
"id": "inspirar",
"status": "implemented",
"summary": "Aumenta ATK de adjacentes.",
"timing": "combate",
"tooltip": "Enquanto estiver em campo, criaturas aliadas adjacentes ganham +X ATK durante o ciclo de combate."
}, {
"display_name": "Pacto",
"id": "pacto",
"status": "implemented",
"summary": "Par em campo ganha +2/+2.",
"timing": "continuo",
"tooltip": "Quando duas criaturas com Pacto estao no campo aliado, ambas ganham +2/+2 enquanto a outra existir."
}, {
"display_name": "Drenar Almas",
"id": "drenar_almas",
"scope": "elite_or_boss_recommended",
"status": "implemented",
"summary": "Kill gera Almas bonus.",
"timing": "morte_inimiga",
"tooltip": "Quando mata uma criatura inimiga, gera Almas bonus igual ao ATK da criatura morta."
}, {
"display_name": "Ressurgir",
"id": "ressurgir",
"status": "implemented",
"summary": "Retorna uma vez enfraquecida.",
"timing": "morte",
"tooltip": "Quando morre, retorna uma vez com metade do ATK e HP originais, arredondado para baixo, sem keywords."
}],
